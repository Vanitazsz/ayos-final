{
  "name": "a-yos",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.23.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "format:check": "prettier --check .",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "typecheck": "turbo run typecheck",
    "verify": "pnpm verify:stack && pnpm format:check && pnpm lint && pnpm typecheck && pnpm functions:check && pnpm functions:test && pnpm test && pnpm traceability:check && pnpm contracts:check && pnpm build",
    "verify:stack": "bash scripts/verify-stack.sh",
    "verify:ci": "bash scripts/ci.sh",
    "supabase:start": "supabase start",
    "supabase:local": "bash scripts/local-supabase.sh",
    "supabase:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:lint": "supabase db lint --level error",
    "test:db": "supabase test db",
    "db:types": "supabase gen types typescript --local > packages/supabase/src/database.generated.ts",
    "functions:serve": "supabase functions serve --env-file supabase/.env.local",
    "functions:check": "deno check --config supabase/functions/deno.json supabase/functions/ai-analyze-request/index.ts supabase/functions/ai-assist-media/index.ts supabase/functions/ai-process-job/index.ts supabase/functions/ai-translate-message/index.ts supabase/functions/geocode-search/index.ts supabase/functions/geocode-reverse/index.ts supabase/functions/route/index.ts supabase/functions/queue-consumer/index.ts supabase/functions/report-export/index.ts supabase/functions/admin-invite-account/index.ts supabase/functions/record-auth-session/index.ts",
    "functions:test": "deno test --allow-env supabase/functions/_shared/expo-push.test.ts",
    "admin:bootstrap": "tsx scripts/bootstrap-admin.ts",
    "traceability:check": "tsx scripts/check-traceability.ts",
    "contracts:check": "bash scripts/check-frontend-backend-contracts.sh"
  },
  "devDependencies": {
    "@eslint/js": "9.38.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "24.10.0",
    "eslint": "9.38.0",
    "prettier": "3.6.2",
    "supabase": "2.109.1",
    "tsx": "4.20.6",
    "turbo": "2.5.8",
    "typescript": "5.9.3",
    "typescript-eslint": "8.46.2",
    "vitest": "4.1.10"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "tests/*"
  ]
}
