RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=10
OTP_TTL_SECONDS=300
RESET_TOKEN_TTL_SECONDS=1800
EMAIL_VERIFICATION_TTL_SECONDS=86400
