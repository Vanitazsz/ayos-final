{
  "name": "ayos-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npm run prisma:generate && tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prisma:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:validate": "prisma validate",
    "db:format": "prisma format"
  },
  "dependencies": {
    "@prisma/client": "7.9.0",
    "@prisma/adapter-pg": "7.9.0",
    "bcrypt": "6.0.0",
    "compression": "1.8.1",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-rate-limit": "8.6.0",
    "file-type": "22.0.1",
    "helmet": "8.3.0",
    "hpp": "0.2.3",
    "jose": "6.2.3",
    "multer": "2.2.0",
    "nodemailer": "9.0.3",
    "pg": "8.22.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/compression": "1.8.1",
    "@types/bcrypt": "6.0.0",
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/hpp": "0.2.7",
    "@types/multer": "2.0.0",
    "@types/node": "26.1.1",
    "@types/nodemailer": "8.0.1",
    "@types/pg": "8.20.0",
    "@types/supertest": "7.2.1",
    "@vitest/coverage-v8": "4.1.10",
    "@eslint/js": "10.0.1",
    "eslint": "10.0.0",
    "prisma": "7.9.0",
    "supertest": "7.2.2",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.65.0",
    "vitest": "4.1.10"
  }
}
