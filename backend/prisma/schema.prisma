  reporterId String           @map("reporter_id") @db.Uuid
  assigneeId String?          @map("assignee_id") @db.Uuid
  bookingId  String?          @map("booking_id") @db.Uuid
  subject    String           @db.VarChar(250)
  category   String           @db.VarChar(100)
  priority   TicketPriority   @default(MEDIUM)
  status     TicketStatus     @default(OPEN)
  resolution String?          @db.VarChar(2000)
  resolvedAt DateTime?        @map("resolved_at") @db.Timestamptz(6)
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt  DateTime?        @map("deleted_at") @db.Timestamptz(6)
  reporter   User             @relation("TicketReporter", fields: [reporterId], references: [id], onDelete: Restrict)
  assignee   User?            @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  booking    Booking?         @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  messages   SupportMessage[]

  @@index([reporterId, status, createdAt])
  @@index([assigneeId, status, priority])
  @@index([status, priority, createdAt])
  @@map("support_tickets")
}

model SupportMessage {
  id          String                     @id @default(uuid()) @db.Uuid
  ticketId    String                     @map("ticket_id") @db.Uuid
  authorId    String                     @map("author_id") @db.Uuid
  message     String                     @db.VarChar(5000)
  internal    Boolean                    @default(false)
  createdAt   DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  ticket      SupportTicket              @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author      User                       @relation(fields: [authorId], references: [id], onDelete: Restrict)
  attachments SupportMessageAttachment[]

  @@index([ticketId, createdAt])
  @@map("support_messages")
}

model SupportMessageAttachment {
  messageId String         @map("message_id") @db.Uuid
  uploadId  String         @unique @map("upload_id") @db.Uuid
  message   SupportMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  upload    Upload         @relation(fields: [uploadId], references: [id], onDelete: Restrict)

  @@id([messageId, uploadId])
  @@map("support_message_attachments")
}

model Upload {
  id                   String                    @id @default(uuid()) @db.Uuid
  ownerId              String                    @map("owner_id") @db.Uuid
  purpose              String                    @db.VarChar(64)
  storageDriver        String                    @map("storage_driver") @db.VarChar(32)
  storageKey           String                    @unique @map("storage_key") @db.VarChar(500)
  originalName         String                    @map("original_name") @db.VarChar(255)
  mimeType             String                    @map("mime_type") @db.VarChar(120)
  sizeBytes            Int                       @map("size_bytes")
  checksumSha256       String                    @map("checksum_sha256") @db.Char(64)
  visibility           UploadVisibility          @default(PRIVATE)
  status               UploadStatus              @default(PENDING)
  createdAt            DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  attachedAt           DateTime?                 @map("attached_at") @db.Timestamptz(6)
  deletedAt            DateTime?                 @map("deleted_at") @db.Timestamptz(6)
  owner                User                      @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  profileAvatar        Profile?                  @relation("ProfileAvatar")
  workerPortfolio      WorkerPortfolio?
  verificationDocument VerificationDocument?
  requestAttachment    RequestAttachment?
  messageAttachment    MessageAttachment?
  reviewAttachment     ReviewAttachment?
  supportAttachment    SupportMessageAttachment?
  reportOutput         Report?                   @relation("ReportOutput")

  @@index([ownerId, purpose, status])
  @@index([status, attachedAt, createdAt])
  @@map("uploads")
}

model PlatformSetting {
  id            String   @id @default(uuid()) @db.Uuid
  key           String   @unique @db.VarChar(120)
  value         Json
  schemaVersion Int      @default(1) @map("schema_version")
  updatedById   String?  @map("updated_by_id") @db.Uuid
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy     User?    @relation(fields: [updatedById], references: [id], onDelete: SetNull)

  @@map("platform_settings")
}

model Report {
  id             String       @id @default(uuid()) @db.Uuid
  requestedById  String       @map("requested_by_id") @db.Uuid
  type           String       @db.VarChar(100)
  format         String       @db.VarChar(16)
  periodStart    DateTime?    @map("period_start") @db.Timestamptz(6)
  periodEnd      DateTime?    @map("period_end") @db.Timestamptz(6)
  status         ReportStatus @default(PENDING)
  outputUploadId String?      @unique @map("output_upload_id") @db.Uuid
  errorMessage   String?      @map("error_message") @db.VarChar(1000)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  completedAt    DateTime?    @map("completed_at") @db.Timestamptz(6)
  requestedBy    User         @relation(fields: [requestedById], references: [id], onDelete: Restrict)
  output         Upload?      @relation("ReportOutput", fields: [outputUploadId], references: [id], onDelete: SetNull)

  @@index([requestedById, status, createdAt])
  @@index([type, status, createdAt])
  @@map("reports")
}

model AuditLog {
  id         String       @id @default(uuid()) @db.Uuid
  actorId    String?      @map("actor_id") @db.Uuid
  sessionId  String?      @map("session_id") @db.Uuid
  requestId  String?      @map("request_id") @db.VarChar(100)
  action     String       @db.VarChar(120)
  module     String       @db.VarChar(64)
  targetType String?      @map("target_type") @db.VarChar(64)
  targetId   String?      @map("target_id") @db.VarChar(100)
  outcome    AuditOutcome
  ipAddress  String?      @map("ip_address") @db.VarChar(64)
  userAgent  String?      @map("user_agent") @db.VarChar(500)
  metadata   Json?
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  actor      User?        @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  session    Session?     @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([actorId, createdAt])
  @@index([module, createdAt])
  @@index([targetType, targetId])
  @@index([requestId])
  @@map("audit_logs")
}

model DeletionRecord {
  id          String    @id @default(uuid()) @db.Uuid
  entityType  String    @map("entity_type") @db.VarChar(64)
  entityId    String    @map("entity_id") @db.VarChar(100)
  displayName String    @map("display_name") @db.VarChar(250)
  deletedById String    @map("deleted_by_id") @db.Uuid
  deletedAt   DateTime  @default(now()) @map("deleted_at") @db.Timestamptz(6)
  purgeAfter  DateTime  @map("purge_after") @db.Timestamptz(6)
  restoredAt  DateTime? @map("restored_at") @db.Timestamptz(6)
  purgedAt    DateTime? @map("purged_at") @db.Timestamptz(6)
  deletedBy   User      @relation("DeletionActor", fields: [deletedById], references: [id], onDelete: Restrict)

  @@unique([entityType, entityId])
  @@index([entityType, restoredAt, purgedAt, deletedAt])
  @@map("deletion_records")
}
