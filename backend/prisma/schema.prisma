generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AccountStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DISABLED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum TokenPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum OtpPurpose {
  PHONE_VERIFICATION
  LOGIN
}

enum EmploymentType {
  EMPLOYED
  FREELANCE
}

enum WorkerVerificationStatus {
  DRAFT
  PENDING
  NEEDS_DOCUMENTS
  APPROVED
  REJECTED
}

enum AvailabilityStatus {
  ONLINE
  OFFLINE
  BUSY
}

enum DocumentStatus {
  MISSING
  UPLOADED
  VERIFIED
  REJECTED
}

enum CatalogStatus {
  ACTIVE
  INACTIVE
}

enum RequestUrgency {
  ASAP
  THIS_WEEK
  OPEN_BIDDING
}

enum ServiceRequestStatus {
  DRAFT
  SEARCHING
  POSTED
  SCHEDULED
  ACCEPTED
  EN_ROUTE
  ARRIVED
  IN_PROGRESS
  PENDING_CONFIRMATION
  COMPLETED
  CANCELLED
}

enum AttachmentType {
  PHOTO
  AUDIO
  DOCUMENT
}

enum BidStatus {
  ACTIVE
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum BookingStatus {
  HIRED
  ACCEPTED
  EN_ROUTE
  ARRIVED
  IN_PROGRESS
  PENDING_CONFIRMATION
  COMPLETED
  CANCELLED
  REFUNDED
}

enum CancellationStage {
  BEFORE_TRAVELING
  AFTER_ARRIVING
  AFTER_INSPECTING
}

enum PaymentStatus {
  PENDING
  REQUIRES_ACTION
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  PARTIALLY_REFUNDED
  REFUNDED
}

enum RefundStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum LedgerDirection {
  CREDIT
  DEBIT
}

enum WalletTransactionType {
  JOB_EARNING
  COMMISSION
  PAYOUT
  TOP_UP
  REFUND
  ADJUSTMENT
}

enum WalletTransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum ReviewStatus {
  PUBLISHED
  HIDDEN
  FLAGGED
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  PUSH
}

enum CampaignAudience {
  ALL_USERS
  WORKERS_ONLY
  CUSTOMERS_ONLY
  INACTIVE_USERS
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
  CANCELLED
}

enum DeliveryStatus {
  PENDING
  SENT
  DELIVERED
  OPENED
  FAILED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

enum TicketStatus {
  OPEN
  PENDING
  ESCALATED
  RESOLVED
  CLOSED
}

enum UploadVisibility {
  PUBLIC
  PRIVATE
}

enum UploadStatus {
  PENDING
  ACTIVE
  DELETED
}

enum ReportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AuditOutcome {
  SUCCESS
  FAILURE
  DENIED
}

model User {
  id                      String                    @id @default(uuid()) @db.Uuid
  email                   String                    @unique @db.VarChar(320)
  phone                   String?                   @unique @db.VarChar(32)
  passwordHash            String                    @map("password_hash") @db.VarChar(255)
  status                  AccountStatus             @default(PENDING)
  emailVerifiedAt         DateTime?                 @map("email_verified_at") @db.Timestamptz(6)
  phoneVerifiedAt         DateTime?                 @map("phone_verified_at") @db.Timestamptz(6)
  tokenVersion            Int                       @default(0) @map("token_version")
  lastLoginAt             DateTime?                 @map("last_login_at") @db.Timestamptz(6)
  createdAt               DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt               DateTime?                 @map("deleted_at") @db.Timestamptz(6)
  profile                 Profile?
  roles                   UserRole[]
  sessions                Session[]
  verificationTokens      VerificationToken[]
  otpChallenges           OtpChallenge[]
  consents                Consent[]
  addresses               Address[]
  settings                UserSetting[]
  workerProfile           WorkerProfile?
  favorites               Favorite[]
  favoritedBy             Favorite[]                @relation("FavoriteProvider")
  verificationDocuments   VerificationDocument[]
  requests                ServiceRequest[]          @relation("CustomerRequests")
  selectedForRequests     ServiceRequest[]          @relation("SelectedWorkerRequests")
  bids                    JobBid[]                  @relation("BidWorker")
  customerBookings        Booking[]                 @relation("CustomerBookings")
  workerBookings          Booking[]                 @relation("WorkerBookings")
  bookingTransitions      BookingStatusHistory[]    @relation("BookingTransitionActor")
  bookingCancellations    BookingCancellation[]     @relation("BookingCancellationActor")
  conversationMemberships ConversationParticipant[]
  sentMessages            Message[]
  payments                Payment[]                 @relation("PaymentCustomer")
  requestedRefunds        Refund[]                  @relation("RefundRequester")
  reviewsWritten          Review[]                  @relation("ReviewAuthor")
  reviewsReceived         Review[]                  @relation("ReviewSubject")
  reviewVotes             ReviewVote[]
  reviewReports           ReviewReport[]
  reviewReplies           ReviewReply[]
  notifications           Notification[]
  createdCampaigns        NotificationCampaign[]    @relation("CampaignCreator")
  notificationDeliveries  NotificationDelivery[]
  supportTickets          SupportTicket[]           @relation("TicketReporter")
  assignedTickets         SupportTicket[]           @relation("TicketAssignee")
  supportMessages         SupportMessage[]
  uploads                 Upload[]
  paymentMethods          CustomerPaymentMethod[]
  updatedSettings         PlatformSetting[]
  reports                 Report[]
  auditLogs               AuditLog[]                @relation("AuditActor")
  reviewedDocuments       VerificationDocument[]    @relation("DocumentReviewer")
  deletionRecords         DeletionRecord[]          @relation("DeletionActor")

  @@index([status, createdAt])
  @@index([deletedAt])
  @@map("users")
}

model Profile {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @unique @map("user_id") @db.Uuid
  firstName      String    @map("first_name") @db.VarChar(100)
  middleName     String?   @map("middle_name") @db.VarChar(100)
  lastName       String    @map("last_name") @db.VarChar(100)
  birthday       DateTime? @db.Date
  gender         Gender?
  avatarUploadId String?   @unique @map("avatar_upload_id") @db.Uuid
  locale         String    @default("en-PH") @db.VarChar(16)
  subdivisionId  String?   @map("subdivision_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatar         Upload?   @relation("ProfileAvatar", fields: [avatarUploadId], references: [id], onDelete: SetNull)
  subdivision    Subdivision? @relation("CustomerSubdivision", fields: [subdivisionId], references: [id], onDelete: SetNull)

  @@map("profiles")
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique @db.VarChar(64)
  name        String           @db.VarChar(100)
  description String?          @db.VarChar(500)
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique @db.VarChar(100)
  description String?          @db.VarChar(500)
  roles       RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz(6)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model Session {
  id                  String     @id @default(uuid()) @db.Uuid
  userId              String     @map("user_id") @db.Uuid
  tokenHash           String     @unique @map("token_hash") @db.VarChar(128)
  familyId            String     @map("family_id") @db.Uuid
  expiresAt           DateTime   @map("expires_at") @db.Timestamptz(6)
  lastUsedAt          DateTime?  @map("last_used_at") @db.Timestamptz(6)
  revokedAt           DateTime?  @map("revoked_at") @db.Timestamptz(6)
  replacedBySessionId String?    @unique @map("replaced_by_session_id") @db.Uuid
  ipAddress           String?    @map("ip_address") @db.VarChar(64)
  userAgent           String?    @map("user_agent") @db.VarChar(500)
  createdAt           DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  user                User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  replacement         Session?   @relation("SessionRotation", fields: [replacedBySessionId], references: [id], onDelete: SetNull)
  replacedSession     Session?   @relation("SessionRotation")
  auditLogs           AuditLog[]

  @@index([userId, revokedAt, expiresAt])
  @@index([familyId])
  @@map("sessions")
}

model VerificationToken {
  id         String       @id @default(uuid()) @db.Uuid
  userId     String       @map("user_id") @db.Uuid
  purpose    TokenPurpose
  tokenHash  String       @unique @map("token_hash") @db.VarChar(128)
  expiresAt  DateTime     @map("expires_at") @db.Timestamptz(6)
  consumedAt DateTime?    @map("consumed_at") @db.Timestamptz(6)
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, consumedAt])
  @@map("verification_tokens")
}

model OtpChallenge {
  id          String     @id @default(uuid()) @db.Uuid
  userId      String     @map("user_id") @db.Uuid
  purpose     OtpPurpose
  codeHash    String     @map("code_hash") @db.VarChar(128)
  expiresAt   DateTime   @map("expires_at") @db.Timestamptz(6)
  attempts    Int        @default(0)
  maxAttempts Int        @default(5) @map("max_attempts")
  consumedAt  DateTime?  @map("consumed_at") @db.Timestamptz(6)
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, consumedAt, expiresAt])
  @@map("otp_challenges")
}

model Consent {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  type       String   @db.VarChar(64)
  version    String   @db.VarChar(32)
  acceptedAt DateTime @default(now()) @map("accepted_at") @db.Timestamptz(6)
  ipAddress  String?  @map("ip_address") @db.VarChar(64)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, version])
  @@map("consents")
}

model Address {
  id           String           @id @default(uuid()) @db.Uuid
  userId       String           @map("user_id") @db.Uuid
  label        String?          @db.VarChar(60)
  streetNumber String?          @map("street_number") @db.VarChar(50)
  street       String           @db.VarChar(200)
  district     String?          @db.VarChar(150)
  city         String           @db.VarChar(150)
  region       String           @db.VarChar(150)
  postalCode   String?          @map("postal_code") @db.VarChar(20)
  countryCode  String           @default("PH") @map("country_code") @db.Char(2)
  latitude     Decimal?         @db.Decimal(10, 7)
  longitude    Decimal?         @db.Decimal(10, 7)
  isDefault    Boolean          @default(false) @map("is_default")
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?        @map("deleted_at") @db.Timestamptz(6)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  requests     ServiceRequest[]

  @@index([userId, isDefault, deletedAt])
  @@map("addresses")
}

model UserSetting {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  key       String   @db.VarChar(100)
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
  @@map("user_settings")
}

model Industry {
  id       String          @id @default(uuid()) @db.Uuid
  code     String          @unique @db.VarChar(64)
  name     String          @unique @db.VarChar(100)
  isActive Boolean         @default(true) @map("is_active")
  skills   Skill[]
  workers  WorkerProfile[]

  @@map("industries")
}

model Skill {
  id         String        @id @default(uuid()) @db.Uuid
  industryId String        @map("industry_id") @db.Uuid
  code       String        @db.VarChar(100)
  name       String        @db.VarChar(120)
  isActive   Boolean       @default(true) @map("is_active")
  industry   Industry      @relation(fields: [industryId], references: [id], onDelete: Restrict)
  workers    WorkerSkill[]

  @@unique([industryId, code])
  @@index([industryId, isActive])
  @@map("skills")
}

model WorkerProfile {
  id                  String                   @id @default(uuid()) @db.Uuid
  userId              String                   @unique @map("user_id") @db.Uuid
  industryId          String                   @map("industry_id") @db.Uuid
  employmentType      EmploymentType           @map("employment_type")
  bio                 String?                  @db.VarChar(2000)
  yearsExperience     Int                      @default(0) @map("years_experience")
  hourlyRate          Int?                     @map("hourly_rate")
  currency            String                   @default("PHP") @db.Char(3)
  verificationStatus  WorkerVerificationStatus @default(DRAFT) @map("verification_status")
  availabilityStatus  AvailabilityStatus       @default(OFFLINE) @map("availability_status")
  contactPerson       String?                  @map("contact_person") @db.VarChar(150)
  contactPhone        String?                  @map("contact_phone") @db.VarChar(32)
  ratingAverage       Decimal                  @default(0) @map("rating_average") @db.Decimal(3, 2)
  ratingCount         Int                      @default(0) @map("rating_count")
  completedJobs       Int                      @default(0) @map("completed_jobs")
  recommendationPriority Boolean               @default(false) @map("recommendation_priority")
  subdivisionId       String?                  @map("subdivision_id") @db.Uuid
  activationFeePaidAt DateTime?                @map("activation_fee_paid_at") @db.Timestamptz(6)
  submittedAt         DateTime?                @map("submitted_at") @db.Timestamptz(6)
  approvedAt          DateTime?                @map("approved_at") @db.Timestamptz(6)
  rejectedAt          DateTime?                @map("rejected_at") @db.Timestamptz(6)
  rejectionReason     String?                  @map("rejection_reason") @db.VarChar(1000)
  createdAt           DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt           DateTime?                @map("deleted_at") @db.Timestamptz(6)
  user                User                     @relation(fields: [userId], references: [id], onDelete: Restrict)
  industry            Industry                 @relation(fields: [industryId], references: [id], onDelete: Restrict)
  skills              WorkerSkill[]
  serviceAreas        WorkerServiceArea[]
  portfolio           WorkerPortfolio[]
  documents           VerificationDocument[]   @relation("WorkerDocuments")
  matches             RequestMatch[]
  wallet              Wallet?
  payoutMethods       PayoutMethod[]
  payouts             Payout[]
  subdivision         Subdivision?             @relation("WorkerSubdivision", fields: [subdivisionId], references: [id], onDelete: SetNull)

  @@index([industryId, verificationStatus, availabilityStatus])
  @@index([ratingAverage, completedJobs])
  @@index([deletedAt])
  @@index([subdivisionId, verificationStatus, availabilityStatus])
  @@map("worker_profiles")
}

model Subdivision {
  id            String          @id @default(uuid()) @db.Uuid
  name          String          @unique @db.VarChar(160)
  centerLat     Decimal         @map("center_lat") @db.Decimal(10, 7)
  centerLng     Decimal         @map("center_lng") @db.Decimal(10, 7)
  radiusMeters  Int             @default(2000) @map("radius_meters")
  boundary      Json?
  isActive      Boolean         @default(true) @map("is_active")
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  customers     Profile[]       @relation("CustomerSubdivision")
  workers       WorkerProfile[] @relation("WorkerSubdivision")
  requests      ServiceRequest[]

  @@index([isActive, name])
  @@map("subdivisions")
}

model WorkerSkill {
  workerId  String        @map("worker_id") @db.Uuid
  skillId   String        @map("skill_id") @db.Uuid
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  worker    WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)
  skill     Skill         @relation(fields: [skillId], references: [id], onDelete: Restrict)

  @@id([workerId, skillId])
  @@index([skillId])
  @@map("worker_skills")
}

model WorkerServiceArea {
  id        String        @id @default(uuid()) @db.Uuid
  workerId  String        @map("worker_id") @db.Uuid
  label     String        @db.VarChar(150)
  latitude  Decimal?      @db.Decimal(10, 7)
  longitude Decimal?      @db.Decimal(10, 7)
  radiusKm  Decimal?      @map("radius_km") @db.Decimal(6, 2)
  worker    WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([workerId, label])
  @@map("worker_service_areas")
}

model WorkerPortfolio {
  id        String        @id @default(uuid()) @db.Uuid
  workerId  String        @map("worker_id") @db.Uuid
  uploadId  String        @unique @map("upload_id") @db.Uuid
  caption   String?       @db.VarChar(300)
  sortOrder Int           @default(0) @map("sort_order")
  worker    WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)
  upload    Upload        @relation(fields: [uploadId], references: [id], onDelete: Restrict)

  @@index([workerId, sortOrder])
  @@map("worker_portfolio")
}

model VerificationDocument {
  id           String         @id @default(uuid()) @db.Uuid
  workerId     String?        @map("worker_id") @db.Uuid
  userId       String?        @map("user_id") @db.Uuid
  uploadId     String         @unique @map("upload_id") @db.Uuid
  type         String         @db.VarChar(64)
  side         String?        @db.VarChar(20)
  status       DocumentStatus @default(UPLOADED)
  expiresAt    DateTime?      @map("expires_at") @db.Date
  reviewedById String?        @map("reviewed_by_id") @db.Uuid
  reviewedAt   DateTime?      @map("reviewed_at") @db.Timestamptz(6)
  remarks      String?        @db.VarChar(1000)
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  worker       WorkerProfile? @relation("WorkerDocuments", fields: [workerId], references: [id], onDelete: Cascade)
  user         User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  upload       Upload         @relation(fields: [uploadId], references: [id], onDelete: Restrict)
  reviewedBy   User?          @relation("DocumentReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([workerId, status])
  @@index([userId, status])
  @@map("verification_documents")
}

model ServiceCategory {
  id          String           @id @default(uuid()) @db.Uuid
  slug        String           @unique @db.VarChar(100)
  name        String           @unique @db.VarChar(120)
  icon        String?          @db.VarChar(64)
  color       String?          @db.VarChar(16)
  description String?          @db.VarChar(1000)
  status      CatalogStatus    @default(ACTIVE)
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?        @map("deleted_at") @db.Timestamptz(6)
  services    Service[]
  requests    ServiceRequest[]

  @@index([status, deletedAt])
  @@map("service_categories")
}

model Service {
  id              String           @id @default(uuid()) @db.Uuid
  categoryId      String           @map("category_id") @db.Uuid
  slug            String           @unique @db.VarChar(120)
  name            String           @db.VarChar(150)
  description     String?          @db.VarChar(2000)
  basePrice       Int?             @map("base_price")
  currency        String           @default("PHP") @db.Char(3)
  durationMinutes Int?             @map("duration_minutes")
  status          CatalogStatus    @default(ACTIVE)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?        @map("deleted_at") @db.Timestamptz(6)
  category        ServiceCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  requests        ServiceRequest[]
  bookings        Booking[]

  @@unique([categoryId, name])
  @@index([categoryId, status, deletedAt])
  @@map("services")
}

model Favorite {
  userId     String   @map("user_id") @db.Uuid
  providerId String   @map("provider_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider   User     @relation("FavoriteProvider", fields: [providerId], references: [id], onDelete: Cascade)

  @@id([userId, providerId])
  @@index([providerId])
  @@map("favorites")
}

model ServiceRequest {
  id               String               @id @default(uuid()) @db.Uuid
  customerId       String               @map("customer_id") @db.Uuid
  selectedWorkerId String?              @map("selected_worker_id") @db.Uuid
  categoryId       String               @map("category_id") @db.Uuid
  serviceId        String?              @map("service_id") @db.Uuid
  addressId        String?              @map("address_id") @db.Uuid
  description      String               @db.VarChar(5000)
  urgency          RequestUrgency?
  status           ServiceRequestStatus @default(DRAFT)
  budgetMin        Int?                 @map("budget_min")
  budgetMax        Int?                 @map("budget_max")
  currency         String               @default("PHP") @db.Char(3)
  scheduledAt      DateTime?            @map("scheduled_at") @db.Timestamptz(6)
  addressText      String?              @map("address_text") @db.VarChar(500)
  latitude         Decimal?             @db.Decimal(10, 7)
  longitude        Decimal?             @db.Decimal(10, 7)
  radiusKm         Decimal?             @default(10) @map("radius_km") @db.Decimal(6, 2)
  subdivisionId    String?              @map("subdivision_id") @db.Uuid
  hasParts         Boolean?             @map("has_parts")
  partsDescription String?              @map("parts_description") @db.VarChar(1000)
  publishedAt      DateTime?            @map("published_at") @db.Timestamptz(6)
  version          Int                  @default(1)
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
